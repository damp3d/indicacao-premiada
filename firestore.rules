rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'admin@damp3d.com';
    }

    function storeExists(storeId) {
      return exists(/databases/$(database)/documents/stores/$(storeId));
    }

    function isStoreOwner(storeId) {
      return isSignedIn() &&
        storeExists(storeId) &&
        get(/databases/$(database)/documents/stores/$(storeId)).data.authUid == request.auth.uid;
    }

    match /system/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stores/{storeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /referrers/{referrerId} {
      allow create: if isAdmin() || isStoreOwner(request.resource.data.storeId);
      allow read: if isAdmin() || isStoreOwner(resource.data.storeId);
      allow update, delete: if isAdmin() || isStoreOwner(resource.data.storeId);
    }

    match /referrals/{referralId} {
      allow create: if true;
      allow read: if isAdmin() || isStoreOwner(resource.data.storeId);
      allow update, delete: if isAdmin() || isStoreOwner(resource.data.storeId);
    }

    match /redeemRequests/{redeemId} {
      allow create: if isAdmin() || isStoreOwner(request.resource.data.storeId);
      allow read: if isAdmin() || isStoreOwner(resource.data.storeId);
      allow update, delete: if isAdmin() || isStoreOwner(resource.data.storeId);
    }
  }
}
